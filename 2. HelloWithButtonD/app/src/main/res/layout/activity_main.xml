<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">
    <!-- match_parent: occupo tutto lo spazio del container in cui vengo inserito -->

    <Button
        android:id="@+id/bu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/press_me"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
        <!-- wrap_content: dimensione sufficiente a contenere il testo -->
        <!-- Android ridisegna l'UI quando cambia il contenuto -->


    <TextView
        android:id="@+id/tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/please_press"
        app:layout_constraintStart_toEndOf="@+id/bu"
        app:layout_constraintBaseline_toBaselineOf="@+id/bu" />
        <!-- i nomi devono essere concordi con il cs per poter utilizzare la reference -->
</androidx.constraintlayout.widget.ConstraintLayout>
